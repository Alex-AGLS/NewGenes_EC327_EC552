# -----------------------------------------------------------------------------
# Model weights — far too large for git, redownload from HuggingFace
# -----------------------------------------------------------------------------
*.gguf
*.safetensors
*.bin
*.pt
*.pth
*.ckpt

# Model directories
qwen35-27b-*/
gemma-4-*/
gemma4-*/
newgenes-adapter*
adapters/
checkpoints/
mlx_models/

# -----------------------------------------------------------------------------
# Secrets — never commit API keys, credentials, or .env files
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.key
*_api_key*
*credentials*
secrets/

# -----------------------------------------------------------------------------
# Large raw outputs — keep summaries, skip full 400 KB+ response dumps if
# your submission has a size limit. Uncomment to exclude:
# -----------------------------------------------------------------------------
# opus_responses.json
# biology_review_mac_mlx_q8_lora_fix.json
# sbol_eval_v2_*_s3.json
# sbol_eval_v2_gemma_udq3km_*.json
# (keep sbol_eval_v2_*.summary.json — they are small and authoritative)

# -----------------------------------------------------------------------------
# Dataset backups (keep active train.jsonl / valid.jsonl / test.jsonl)
# -----------------------------------------------------------------------------
mlx_data/*.bak.*
*.jsonl.bak.*
*.bak

# -----------------------------------------------------------------------------
# Eval intermediate / scratch directories
# -----------------------------------------------------------------------------
eval_results/scratch/
eval_results/tmp/
*.tmp
*.log

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
.venv/
venv/
env/

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_convert

# -----------------------------------------------------------------------------
